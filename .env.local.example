# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string. Use MongoDB Atlas for production.
# Example: mongodb+srv://user:pass@cluster.mongodb.net/portfolio
MONGODB_URI=mongodb://localhost:27017/portfolio

# ─── Authentication ───────────────────────────────────────────────────────────
# Strong random string for signing JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string

# ─── Admin credentials (used by seed script only) ─────────────────────────────
# The seed script hashes this password before storing it.
# Change immediately after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_immediately

# ─── Public URL ───────────────────────────────────────────────────────────────
# Full URL of your deployment, no trailing slash.
# Used for sitemap, OG images, and metadata.
NEXT_PUBLIC_URL=http://localhost:3000

# ─── File storage (optional) ──────────────────────────────────────────────────
# Vercel Blob token for resume/OG image uploads.
# Leave empty to skip file upload functionality.
# Get from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# Set to "true" to enable custom page-view tracking to MongoDB.
NEXT_PUBLIC_ANALYTICS_ENABLED=true
